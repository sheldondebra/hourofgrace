Options -MultiViews
RewriteEngine On
RewriteBase /

# Requires PHP 8.0+. In cPanel MultiPHP Manager, select PHP 8.1+ for this domain.
# If PHP files return HTTP 500, uncomment the line that matches your cPanel PHP version:
# AddHandler application/x-httpd-ea-php81 .php
# AddHandler application/x-httpd-ea-php82 .php

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Block sensitive directories from web access
RewriteRule ^(includes|sql|storage|vendor)/ - [F,L]

# Leave backend folders and static assets untouched
RewriteRule ^(api|admin|uploads|assets|css|js|data)/ - [L]
RewriteRule ^((install|health|sync-gallery)\.php|.*\.php)$ - [L]

# Redirect root index.html to /
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Redirect legacy *.html URLs to folder URLs
RewriteCond %{THE_REQUEST} \s/+([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1/ [R=301,L]

# Ensure trailing slash on directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+[^/])$ $1/ [R=301,L]

DirectoryIndex index.html
